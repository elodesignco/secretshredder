# Secret Shredder env contract
# Safe to commit. Put real values in .env.local for local dev and in Cloudflare secrets/vars for deploy.

# Public / app config
PUBLIC_SITE_URL=https://secretshredder.com
PRODUCT_NAME=Secret Shredder
DEFAULT_CURRENCY=usd
STRIPE_MODE=payment
WAITLIST_EMAIL_SUBJECT=New Secret Shredder email signup
WAITLIST_EMAIL_TAG=secret-shredder-signups
LAUNCH_EMAIL_SUBJECT=You’re on the Secret Shredder list
BREVO_LIST_ID=2

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_PRODUCT_ID=prod_xxx

# Brevo / launch emails
# Cloudflare-friendly path uses Brevo's HTTP API.
# Keep SMTP_* values only as operator reference / parity with other environments.
BREVO_API_KEY=xkeysib-xxx
NOTIFY_FROM_EMAIL=hello@secretshredder.com
NOTIFY_FROM_NAME=Secret Shredder
NOTIFY_TO_EMAIL=hello@secretshredder.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-login
SMTP_PASSWORD=your-brevo-smtp-password
SMTP_FROM_EMAIL=hello@secretshredder.com
SMTP_FROM_NAME=Secret Shredder
SMTP_REPLY_TO=hello@secretshredder.com

# Optional social / launch ops notes
X_ACCOUNT_ID=change-me
X_ACCOUNT_USERNAME=change-me
X_ACCOUNT_PASSWORD=change-me
